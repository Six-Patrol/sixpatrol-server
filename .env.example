# CockroachDB DSN (Postgres-compatible)
COCKROACH_DSN=postgresql://user:password@localhost:26257/dbname?sslmode=disable

# Qdrant settings
QDRANT_HOST=localhost
QDRANT_PORT=6334
QDRANT_API_KEY=
QDRANT_USE_TLS=false

# Proxy video storage (local or s3)
PROXY_VIDEO_DIR=./media/proxy-video

# S3/R2 settings for proxy video storage
PROXY_VIDEO_BUCKET=
AWS_REGION=auto
AWS_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
